<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F7">

    <!-- Header -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txtBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#007AFF"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pengingat"
            android:textStyle="bold"
            android:textSize="24sp"
            android:textColor="#000000"
            android:gravity="center"/>

    </LinearLayout>

    <TextView
        android:id="@+id/txtTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 Pengingat"
        android:textSize="15sp"
        android:textColor="#8E8E93"
        android:layout_marginStart="24dp"
        android:layout_marginTop="10dp"/>

    <!-- SEARCH -->

    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchReminder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:queryHint="Cari reminder..."
        android:iconifiedByDefault="false"
        app:iconifiedByDefault="false"/>

    <!-- LIST -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerReminder"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"/>

    <!-- EMPTY -->

    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:tint="#C7C7CC"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belum ada reminder"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#8E8E93"
            android:layout_marginTop="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tekan tombol + untuk membuat reminder baru."
            android:textColor="#B0B0B0"
            android:textSize="14sp"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

</LinearLayout>